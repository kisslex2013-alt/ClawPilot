# Temporal
TEMPORAL_NAMESPACE=clawpilot
TEMPORAL_TASK_QUEUE=clawpilot-main
TEMPORAL_ADDRESS=localhost:7233

# Storage / runtime paths
DATABASE_URL=postgresql://clawpilot:clawpilot@localhost:5432/clawpilot
CLAWLOOP_REPO_PATH=/root/clawloop
OPENCLAW_WORKSPACE=/root/.openclaw/workspace
OPENCLAW_CONFIG_PATH=/root/.openclaw/openclaw.json

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PROGRESS_MODE=normal

# Local app settings
CLAWPILOT_LOG_LEVEL=info
CLAWPILOT_ENV=development
